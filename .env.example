# Server port
PORT=3000

# Allowed CORS origin (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Environment mode: development | production | test
NODE_ENV=development

# Maximum request body size (e.g. 10mb, 100mb)
MAX_BODY_SIZE=10mb

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Admin authentication
ADMIN_USER=admin
ADMIN_PASSWORD=

# API key for automated admin access (optional, disable by leaving empty)
API_KEY=
